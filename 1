local function serializeFlagsToString()
	local dat = {}
	for k, v in pairs(flags) do
		if type(v) == "number" or type(v) == "boolean" or type(v) == "string" then dat[k] = v end
	end
	local success, result = pcall(function() return HttpService:JSONEncode(dat) end)
	return success and result or "{}"
end

local function deserializeFlagsFromString(str)
	local success, result = pcall(function() return HttpService:JSONDecode(str) end)
	if success and type(result) == "table" then
		for k, v in pairs(result) do flags[k] = v end
		Notify("Configuration Management", "Successfully extracted cloud payload data.", 4)
	else
		Notify("Deserializer Malfunction", "Invalid or corrupted clipboard profile string data format detected.", 5)
	end
end

