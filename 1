local function purgeESPAssetsForPlayer(p)
	local assets = espCacheRegistry[p]
	if assets then
		if assets.BoxContainer then assets.BoxContainer:Destroy() end
		if assets.Snapline then assets.Snapline:Destroy() end
		if assets.ColorConnection then assets.ColorConnection:Disconnect() end
		if p.Character and p.Character:FindFirstChild("FatalityCham") then
			p.Character.FatalityCham:Destroy()
		end
		espCacheRegistry[p] = nil
	end
end

