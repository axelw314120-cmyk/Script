local espRenderLoop = RunService.RenderStepped:Connect(function()
	if Watermark.Visible then
		local ping = tonumber(string.format("%.0f", player:GetNetworkPing() * 1000))
		WMLabel.Text = string.format("FATALITY.WIN | %s | FPS: %d | Ping: %dms", player.Name, math.floor(1 / RunService.RenderStepped:Wait()), ping)
	end

	for targetPlayer, assets in pairs(espCacheRegistry) do
		local char = targetPlayer.Character
		local hrp = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
		local humanoid = char and char:FindFirstChildOfClass("Humanoid")
		
		if flags.ESP_Master and hrp and humanoid and humanoid.Health > 0 then
			-- Calculate position bounds directly from World Points to handle FOV updates perfectly
			local extentsSize = char:GetExtentsSize()
			local topWorld = (hrp.CFrame * CFrame.new(0, extentsSize.Y / 2, 0)).Position
			local bottomWorld = (hrp.CFrame * CFrame.new(0, -extentsSize.Y / 2, 0)).Position
			
			local topScreen, tOn = Camera:WorldToViewportPoint(topWorld)
			local bottomScreen, bOn = Camera:WorldToViewportPoint(bottomWorld)
			local hrpScreen, hOn = Camera:WorldToViewportPoint(hrp.Position)
			
			-- Bounding Boxes Rendering Updates
			if tOn and bOn and (flags.Box2D or flags.ESP_Names or flags.ESP_Health) then
				local boxHeight = math.abs(bottomScreen.Y - topScreen.Y)
				local boxWidth = boxHeight * 0.65
				
				assets.BoxContainer.Position = UDim2.new(0, topScreen.X - (boxWidth / 2), 0, topScreen.Y)
				assets.BoxContainer.Size = UDim2.new(0, boxWidth, 0, boxHeight)
				assets.BoxContainer.Visible = flags.Box2D
				
				assets.InteriorFill.BackgroundTransparency = flags.BoxFill and 0.85 or 1
				assets.NameTag.Visible = flags.ESP_Names
				
				assets.HealthBar.Visible = flags.ESP_Health
				local hpPct = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
				assets.HealthFill.Size = UDim2.new(1, 0, hpPct, 0)
				assets.HealthFill.Position = UDim2.new(0, 0, 1 - hpPct, 0)
			else
				assets.BoxContainer.Visible = false
			end
			
			-- Snapline Matrix Updates
			if hOn and flags.ESP_Snaplines then
				local startPoint = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
				local endPoint = Vector2.new(hrpScreen.X, hrpScreen.Y)
				local dist = (endPoint - startPoint).Magnitude
				local rads = math.atan2(endPoint.Y - startPoint.Y, endPoint.X - startPoint.X)
				
				assets.Snapline.Size = UDim2.new(0, dist, 0, 1.5)
				assets.Snapline.Position = UDim2.new(0, (startPoint.X + endPoint.X) / 2, 0, (startPoint.Y + endPoint.Y) / 2)
				assets.Snapline.Rotation = math.deg(rads)
				assets.Snapline.Visible = true
			else
				assets.Snapline.Visible = false
			end
			
			-- High Contrast Real-Time Chams Engine Updates
			if flags.Chams then
				local hl = char:FindFirstChild("FatalityCham")
				if not hl then
					hl = Instance.new("Highlight"); hl.Name = "FatalityCham"
					hl.OutlineColor = Color3.fromRGB(255, 255, 255); hl.FillTransparency = 0.4
					hl.Parent = char
				end
				hl.Enabled = true
				hl.FillColor = UIStroke.Color
			else
				local hl = char:FindFirstChild("FatalityCham")
				if hl then hl.Enabled = false end
			end
		else
			-- Invisible fallback states for dead players or disabled master switches
			assets.BoxContainer.Visible = false
			assets.Snapline.Visible = false
			if char then
				local hl = char:FindFirstChild("FatalityCham")
				if hl then hl.Enabled = false end
			end
		end
	end
end)
