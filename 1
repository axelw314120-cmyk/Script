local function createSlider(labelName, flagKey, parentFrame, min, max, default, callback)
	flags[flagKey] = default or min
	
	local RowFrame = Instance.new("Frame")
	RowFrame.Size = UDim2.new(1, 0, 0, 35)
	RowFrame.BackgroundTransparency = 1
	RowFrame.Parent = parentFrame
	
	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(1, -40, 0, 15)
	Label.BackgroundTransparency = 1
	Label.Text = labelName
	Label.TextColor3 = Color3.fromRGB(175, 170, 190)
	Label.TextSize = 12
	Label.Font = Enum.Font.Gotham
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = RowFrame
	
	local ValueLbl = Instance.new("TextLabel")
	ValueLbl.Size = UDim2.new(0, 40, 0, 15)
	ValueLbl.Position = UDim2.new(1, -40, 0, 0)
	ValueLbl.BackgroundTransparency = 1
	ValueLbl.Text = tostring(flags[flagKey])
	ValueLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
	ValueLbl.TextSize = 12
	ValueLbl.Font = Enum.Font.Code
	ValueLbl.TextXAlignment = Enum.TextXAlignment.Right
	ValueLbl.Parent = RowFrame
	
	local SliderBack = Instance.new("TextButton")
	SliderBack.Size = UDim2.new(1, 0, 0, 6)
	SliderBack.Position = UDim2.new(0, 0, 0, 22)
	SliderBack.BackgroundColor3 = Color3.fromRGB(36, 32, 48)
	SliderBack.Text = ""
	SliderBack.AutoButtonColor = false
	SliderBack.Parent = RowFrame
	local SBCorner = Instance.new("UICorner"); SBCorner.CornerRadius = UDim.new(1, 0); SBCorner.Parent = SliderBack
	
	local SliderFill = Instance.new("Frame")
	local initialFill = math.clamp((flags[flagKey] - min) / (max - min), 0, 1)
	SliderFill.Size = UDim2.new(initialFill, 0, 1, 0)
	SliderFill.BackgroundColor3 = UIStroke.Color
	SliderFill.Parent = SliderBack
	local SFCorner = Instance.new("UICorner"); SFCorner.CornerRadius = UDim.new(1, 0); SFCorner.Parent = SliderFill
	
	local propConn = UIStroke:GetPropertyChangedSignal("Color"):Connect(function() SliderFill.BackgroundColor3 = UIStroke.Color end)
	table.insert(activeConnectionsPool, propConn)
	
	local dragging = false
	local function updateSlider(input)
		local relative = math.clamp((input.Position.X - SliderBack.AbsolutePosition.X) / SliderBack.AbsoluteSize.X, 0, 1)
		local val = math.floor(min + ((max - min) * relative))
		flags[flagKey] = val
		ValueLbl.Text = tostring(val)
		TweenService:Create(SliderFill, TweenInfo.new(0.1), {Size = UDim2.new(relative, 0, 1, 0)}):Play()
		if callback then callback(val) end
	end
	
	SliderBack.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true; updateSlider(input)
		end
	end)
	
	local iConn = UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSlider(input)
		end
	end)
	local eConn = UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
	end)
	table.insert(activeConnectionsPool, iConn); table.insert(activeConnectionsPool, eConn)
end

