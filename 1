local function switchTab(targetName)
	if activeTab == targetName then return end
	playClickSFX()
	for name, page in pairs(Pages) do page.Visible = (name == targetName) end
	for name, btn in pairs(TabButtons) do
		btn.TextColor3 = (name == targetName) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 115, 135)
	end
	activeTab = targetName
end
