local function runCollector()
	if running then return end
	running = true
	collectBtn.Text = "Running..."
	collectBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

	local delays = SPEED_DELAYS[collectorConfig.speed] or SPEED_DELAYS.Normal
	local foundThisRun = 0
	sessionData.lastRunSpeed = collectorConfig.speed
	sessionData.speedsUsed[collectorConfig.speed] = true
	local runStartTime = os.clock()

	addLog("Collector started (" .. collectorConfig.speed .. ")", "Info")

	local mobs = workspace:FindFirstChild("Mobs")
	if not mobs then
		statusLabel.Text = "Status: Mobs folder not found"
		addLog("Mobs folder not found", "Error")
		showNotif("Mobs folder not found!", Color3.fromRGB(255, 100, 100))
		running = false
		collectBtn.Text = "Start Collecting"
		collectBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 60)
		return
	end

	repeat
		for _, mob in ipairs(mobs:GetChildren()) do
			if not running then break end
			if foundThisRun >= maxPerRun then break end
			if shouldCollect(mob) then
				local rootPart = mob:FindFirstChild("RootPart")
				if rootPart then
					local rarity = getRarity(mob)
					statusLabel.Text = "Status: Found " .. mob.Name .. " [" .. rarity .. "]"
					addLog("Found: " .. mob.Name .. " [" .. rarity .. "]", "Collect")
					showNotif("Found: " .. mob.Name, RARITY_COLORS[rarity] or LOG_COLORS.Collect)

					teleportTo(rootPart.CFrame + Vector3.new(0, 3, 0))
					task.wait(delays.tp)
					holdE(delays.hold)
					task.wait(delays.after)

					foundThisRun += 1
					local prev = sessionData.collected
					sessionData.collected += 1
					sessionData.rarityCounts[rarity] = (sessionData.rarityCounts[rarity] or 0) + 1
					sessionData.brainrotCounts[mob.Name] = (sessionData.brainrotCounts[mob.Name] or 0) + 1
					playCollectSound()

					if sessionData.collected > sessionData.bestSession then
						sessionData.bestSession = sessionData.collected
						addLog("NEW PERSONAL BEST: " .. sessionData.bestSession .. " OGs!", "Record")
						showNotif("New personal best!", Color3.fromRGB(255, 215, 0))
					end

					animateCounter(sessionLabel, prev, sessionData.collected, "OGs collected this session: ", "")
					statusLabel.Text = "Status: Collected " .. foundThisRun .. "/" .. maxPerRun
					spawnConfetti()
					if listHas(favoriteBrainrots, mob.Name) then
						showNotif("Favorite collected: " .. mob.Name .. " ♥", Color3.fromRGB(255, 150, 180))
					end
					refreshStatsUI()
					checkAchievements()
				end
			end
		end

		if foundThisRun < maxPerRun and collectorConfig.loopMode and running then
			statusLabel.Text = "Status: Loop waiting..."
			for i = collectorConfig.loopWait, 1, -1 do
				if not running then break end
				statusLabel.Text = "Status: Loop in " .. i .. "s"
				task.wait(1)
			end
		end
	until foundThisRun >= maxPerRun or not running or not collectorConfig.loopMode

	if collectorConfig.autoReturn then
		statusLabel.Text = "Status: Returning to safe zone"
		teleportTo(SAFE_ZONE_CFRAME)
		task.wait(0.4)
	end

	local doneMsg = "Done! Collected " .. foundThisRun
	statusLabel.Text = "Status: " .. doneMsg
	addLog(doneMsg, "Collect")
	showNotif(doneMsg, Color3.fromRGB(100, 120, 220))
	sessionData.runsCompleted += 1
	sessionData.totalCollectionTime += (os.clock() - runStartTime)
	addRunHistory("Collect", "Found " .. foundThisRun .. " @ " .. collectorConfig.speed)
	checkAchievements()
	refreshStatsUI()

	running = false
	collectBtn.Text = "Start Collecting"
	collectBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 60)
end

-- ─── HITTER LOGIC ───

local function runHitter()
	if hitting then return end
	hitting = true
	hitBtn.Text = "Hitting..."
	hitBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

	local targets = resolveHitTargets()
	if #targets == 0 then
		hitStatusLabel.Text = "Status: No targets found"
		addLog("No hit targets found", "Error")
		showNotif("No targets!", Color3.fromRGB(255, 120, 100))
		hitting = false
		hitBtn.Text = "Start Hitting"
		hitBtn.BackgroundColor3 = Color3.fromRGB(40, 60, 130)
		return
	end

	equipBat()
	local hitsThisRun = 0
	local runStartTime = os.clock()
	addLog("Hitter started — " .. #targets .. " target(s)", "Hit")

	for _, target in ipairs(targets) do
		if not hitting then break end
		local hrp = target:FindFirstChild("HumanoidRootPart")
		if hrp then
			hitStatusLabel.Text = "Status: Hitting " .. target.Name
			addLog("Hitting: " .. target.Name, "Hit")
			showNotif("Hitting: " .. target.Name, Color3.fromRGB(55, 80, 170))

			local swinging = true
			local trackConnection = RunService.Heartbeat:Connect(function()
				if not swinging then return end
				local updatedHrp = target:FindFirstChild("HumanoidRootPart")
				local char = player.Character
				if updatedHrp and char and char:FindFirstChild("HumanoidRootPart") then
					char.HumanoidRootPart.CFrame = updatedHrp.CFrame * CFrame.new(0, 2, 3)
				end
			end)

			for _ = 1, hitterConfig.swingCount do
				if not hitting then break end
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
				task.wait(0.2)
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
				task.wait(0.5)
				hitsThisRun += 1
				sessionData.totalHits += 1
				playHitSound()
			end

			swinging = false
			trackConnection:Disconnect()

			if hitterConfig.cooldownTime > 0 then
				for cd = hitterConfig.cooldownTime, 1, -1 do
					if not hitting then break end
					hitStatusLabel.Text = "Status: Cooldown " .. cd .. "s"
					task.wait(1)
				end
			else
				task.wait(0.2)
			end
		end
	end

	if collectorConfig.autoReturn then
		hitStatusLabel.Text = "Status: Returning to safe zone"
		teleportTo(SAFE_ZONE_CFRAME)
		task.wait(0.3)
	end

	if hitsThisRun > sessionData.bestHitSession then
		sessionData.bestHitSession = hitsThisRun
		addLog("New best hit session: " .. hitsThisRun, "Record")
	end

	hitStatusLabel.Text = "Status: Done hitting!"
	addLog("Done hitting — " .. hitsThisRun .. " swings", "Hit")
	showNotif("Done hitting!", Color3.fromRGB(55, 80, 170))
	sessionData.hitRunsCompleted += 1
	sessionData.totalHitTime += (os.clock() - runStartTime)
	addRunHistory("Hit", hitsThisRun .. " swings, mode " .. hitterConfig.targetMode)
	checkAchievements()
	refreshStatsUI()

	hitting = false
	hitBtn.Text = "Start Hitting"
	hitBtn.BackgroundColor3 = Color3.fromRGB(40, 60, 130)
end

