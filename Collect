-- ─── HELPERS ───

local function timestamp()
	local t = os.clock() - sessionData.sessionStart
	local m = math.floor(t / 60) % 60
	local s = math.floor(t) % 60
	return string.format("%02d:%02d", m, s)
end

local function formatSessionTime()
	local t = math.floor(os.clock() - sessionData.sessionStart)
	local h = math.floor(t / 3600)
	local m = math.floor((t % 3600) / 60)
	local s = t % 60
	if h > 0 then
		return string.format("%d:%02d:%02d", h, m, s)
	end
	return string.format("%02d:%02d", m, s)
end

local function addLog(msg, logType)
	logType = logType or "Info"
	local color = LOG_COLORS[logType] or LOG_COLORS.Info
	table.insert(logEntries, { text = "[" .. timestamp() .. "] " .. msg, color = color, type = logType })
	while #logEntries > MAX_LOG do
		table.remove(logEntries, 1)
	end
end

local function listHas(list, value)
	for _, v in ipairs(list) do
		if v == value then return true end
	end
	return false
end

local function listRemove(list, value)
	for i, v in ipairs(list) do
		if v == value then
			table.remove(list, i)
			return true
		end
	end
	return false
end

local function teleportTo(cf)
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = cf
		return true
	end
	return false
end

local function holdE(duration)
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	task.wait(duration)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function equipBat()
	local bat = player.Backpack:FindFirstChild("Bat")
		or (player.Character and player.Character:FindFirstChild("Bat"))
	if bat and player.Character then
		local hum = player.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:EquipTool(bat) end
		task.wait(0.35)
	end
end

local function equipToolByName(name)
	local tool = player.Backpack:FindFirstChild(name)
		or (player.Character and player.Character:FindFirstChild(name))
	if tool and player.Character then
		local hum = player.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:EquipTool(tool) end
		return true
	end
	return false
end

local function isBrainrot(name)
	for _, v in ipairs(brainrotNames) do
		if v == name then return true end
	end
	return false
end

local function getRarity(mob)
	local ok, rarity = pcall(function()
		local root = mob:FindFirstChild("RootPart")
		if not root then return nil end
		local attach = root:FindFirstChild("OverheadAttach")
		if not attach then return nil end
		local overhead = attach:FindFirstChild("AnimalOverhead")
		if not overhead then return nil end
		local r = overhead:FindFirstChild("Rarity")
		if r then
			if r:IsA("StringValue") or r:IsA("ValueBase") then return r.Value end
			if r:IsA("TextLabel") then return r.Text end
		end
		return nil
	end)
	if ok and type(rarity) == "string" then
		local lower = rarity:lower()
		if lower == "og" then return "OG" end
		if lower == "rare" then return "Rare" end
		return "Common"
	end
	return "Common"
end

local function shouldCollect(mob)
	if not isBrainrot(mob.Name) then return false end
	if listHas(collectorConfig.blacklist, mob.Name) then return false end
	local rarity = getRarity(mob)
	return collectorConfig.rarityFilter[rarity] == true
end

local function getWorkspaceTargets()
	local targets = {}
	for _, obj in ipairs(workspace:GetChildren()) do
		if obj:IsA("Model")
			and obj.Archivable == false
			and obj ~= player.Character
			and obj:FindFirstChildOfClass("Humanoid")
			and obj:FindFirstChild("HumanoidRootPart")
		then
			if not listHas(hitterConfig.skipList, obj.Name) then
				table.insert(targets, obj)
			end
		end
	end
	return targets
end

local function resolveHitTargets()
	local all = getWorkspaceTargets()
	if hitterConfig.targetMode == "All" then
		return all
	elseif hitterConfig.targetMode == "Random" then
		if #all == 0 then return {} end
		return { all[math.random(1, #all)] }
	elseif hitterConfig.targetMode == "Specific" then
		local picked = {}
		for _, t in ipairs(all) do
			if listHas(hitterConfig.specificTargets, t.Name) then
				table.insert(picked, t)
			end
		end
		return picked
	end
	return all
end

local function animateCounter(label, fromVal, toVal, prefix, suffix)
	prefix = prefix or ""
	suffix = suffix or ""
	local steps = math.min(math.abs(toVal - fromVal), 20)
	if steps <= 0 then
		label.Text = prefix .. toVal .. suffix
		return
	end
	local step = (toVal - fromVal) / steps
	task.spawn(function()
		for i = 1, steps do
			local v = math.floor(fromVal + step * i + 0.5)
			label.Text = prefix .. v .. suffix
			task.wait(0.03)
		end
		label.Text = prefix .. toVal .. suffix
	end)
end

local function rippleButton(btn)
	local ripple = Instance.new("Frame")
	ripple.Size = UDim2.new(0, 10, 0, 10)
	ripple.AnchorPoint = Vector2.new(0.5, 0.5)
	ripple.Position = UDim2.new(0.5, 0, 0.5, 0)
	ripple.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	ripple.BackgroundTransparency = 0.6
	ripple.BorderSizePixel = 0
	ripple.ZIndex = btn.ZIndex + 2
	ripple.Parent = btn
	Instance.new("UICorner", ripple).CornerRadius = UDim.new(1, 0)
	TweenService:Create(ripple, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(1.5, 0, 2, 0),
		BackgroundTransparency = 1,
	}):Play()
	task.delay(0.45, function()
		if ripple.Parent then ripple:Destroy() end
	end)
end

