local function refreshAnalyticsUI()
	local sessionTime = os.clock() - sessionData.sessionStart
	local minutes = sessionTime / 60
	if minutes > 0 then
		local collectRate = sessionData.collected / minutes
		local hitRate = sessionData.totalHits / minutes
		efficiencyLabel.Text = string.format("Collection efficiency: %.2f/min", collectRate)
		hitEfficiencyLabel.Text = string.format("Hit efficiency: %.2f/min", hitRate)
	end
	
	totalCollectTimeLabel.Text = string.format("Total collection time: %.1fs", sessionData.totalCollectionTime)
	totalHitTimeLabel.Text = string.format("Total hit time: %.1fs", sessionData.totalHitTime)
	
	if sessionData.runsCompleted > 0 then
		avgCollectTimeLabel.Text = string.format("Avg time per collect: %.2fs", sessionData.totalCollectionTime / sessionData.runsCompleted)
	else
		avgCollectTimeLabel.Text = "Avg time per collect: 0s"
	end
	
	if sessionData.hitRunsCompleted > 0 then
		avgHitTimeLabel.Text = string.format("Avg time per hit: %.2fs", sessionData.totalHitTime / sessionData.hitRunsCompleted)
	else
		avgHitTimeLabel.Text = "Avg time per hit: 0s"
	end
	
	local speeds = sessionData.speedsUsed
	speedBreakdownLabel.Text = string.format("Insane: %s | Fast: %s | Normal: %s | Careful: %s",
		speeds.Insane and "✓" or "○",
		speeds.Fast and "✓" or "○",
		speeds.Normal and "✓" or "○",
		speeds.Careful and "✓" or "○"
	)
	
	local total = sessionData.rarityCounts.OG + sessionData.rarityCounts.Rare + sessionData.rarityCounts.Common
	if total > 0 then
		local ogPct = math.floor((sessionData.rarityCounts.OG / total) * 100)
		local rarePct = math.floor((sessionData.rarityCounts.Rare / total) * 100)
		local commonPct = 100 - ogPct - rarePct
		rarityPercentLabel.Text = string.format("OG: %d%% | Rare: %d%% | Common: %d%%", ogPct, rarePct, commonPct)
	else
		rarityPercentLabel.Text = "OG: 0% | Rare: 0% | Common: 0%"
	end
	
	local h = sessionTime / 3600
	local m1 = h >= 1 and "✓" or "○"
	local m2 = h >= 2 and "✓" or "○"
	local m3 = h >= 3 and "✓" or "○"
	local m5 = h >= 5 and "✓" or "○"
	milestonesLabel.Text = string.format("1h: %s | 2h: %s | 3h: %s | 5h: %s", m1, m2, m3, m5)
end

