-- ─── MACRO SYSTEM ───

local macroRecording = false
local macroPlaying = false
local macroActions = {}
local macroStartTime = 0

local function startMacroRecording()
	if macroRecording or macroPlaying then return end
	macroRecording = true
	macroActions = {}
	macroStartTime = os.clock()
	addLog("Macro recording started", "Config")
	showNotif("Recording macro...", Color3.fromRGB(100, 180, 255))
end

local function stopMacroRecording()
	if not macroRecording then return end
	macroRecording = false
	addLog("Macro recording stopped — " .. #macroActions .. " actions", "Config")
	showNotif("Macro saved! " .. #macroActions .. " actions", Color3.fromRGB(100, 180, 255))
end

local function playMacro()
	if macroPlaying or macroRecording or #macroActions == 0 then return end
	macroPlaying = true
	addLog("Playing macro — " .. #macroActions .. " actions", "Config")
	showNotif("Playing macro...", Color3.fromRGB(100, 180, 255))
	
	task.spawn(function()
		for i, action in ipairs(macroActions) do
			if not macroPlaying then break end
			task.wait(action.delay)
			if action.type == "teleport" and action.cframe then
				teleportTo(action.cframe)
			elseif action.type == "holdE" then
				holdE(action.duration or 1)
			elseif action.type == "click" then
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
				task.wait(0.1)
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
			end
		end
		macroPlaying = false
		addLog("Macro playback finished", "Config")
		showNotif("Macro finished!", Color3.fromRGB(100, 180, 255))
	end)
end

local function stopMacroPlayback()
	macroPlaying = false
	addLog("Macro playback stopped", "Config")
	showNotif("Macro stopped", Color3.fromRGB(255, 150, 100))
end

-- ─── PERFORMANCE MONITOR ───

local fpsValues = {}
local lastFrameTime = tick()
local currentFPS = 60

local function updateFPS()
	local now = tick()
	local delta = now - lastFrameTime
	lastFrameTime = now
	currentFPS = math.floor(1 / delta)
	
	table.insert(fpsValues, currentFPS)
	if #fpsValues > 60 then
		table.remove(fpsValues, 1)
	end
end

local function getAverageFPS()
	if #fpsValues == 0 then return 60 end
	local sum = 0
	for _, v in ipairs(fpsValues) do
		sum += v
	end
	return math.floor(sum / #fpsValues)
end

local function getPing()
	local stats = game:GetService("StatsService")
	local perfStats = stats:GetPerformanceStats()
	for _, stat in ipairs(perfStats:GetChildren()) do
		if stat.Name == "Ping" then
			return math.floor(stat.Value)
		end
	end
	return 0
end

local function getMemoryMB()
	local stats = game:GetService("StatsService")
	local perfStats = stats:GetPerformanceStats()
	for _, stat in ipairs(perfStats:GetChildren()) do
		if stat.Name == "DataReceiveRate" then
			return math.floor(stat.Value / 1024 / 1024)
		end
	end
	return 0
end

