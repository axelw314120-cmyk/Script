local function makeCozyToggle(scroll, label, key, order, onColor, offColor)
	local btn = makeActionBtn(scroll, label .. ": ON", onColor, 26, order)
	local function refresh()
		local on = cozyConfig[key]
		btn.Text = label .. ": " .. (on and "ON" or "OFF")
		btn.BackgroundColor3 = on and onColor or offColor
	end
	btn.MouseButton1Click:Connect(function()
		cozyConfig[key] = not cozyConfig[key]
		refresh()
		if guiOpen then
			if key == "snowEnabled" then
				snowContainer.Visible = cozyConfig.snowEnabled
				if not cozyConfig.snowEnabled then
					for _, sf in ipairs(snowflakes) do sf.label:Destroy() end
					snowflakes = {}
				end
			elseif key == "firefliesEnabled" then
				fireflyContainer.Visible = cozyConfig.firefliesEnabled
				if not cozyConfig.firefliesEnabled then
					for _, ff in ipairs(fireflies) do ff.label:Destroy() end
					fireflies = {}
				end
			end
		end
		addLog(label .. ": " .. tostring(cozyConfig[key]), "Config")
	end)
	refresh()
	return btn
end

