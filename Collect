local function serializeConfig()
	return HttpService:JSONEncode({
		collectorConfig = collectorConfig,
		hitterConfig = hitterConfig,
		cozyConfig = cozyConfig,
		savedSpots = savedSpots,
		favoriteBrainrots = favoriteBrainrots,
	})
end

local function serializeStats()
	return HttpService:JSONEncode({
		sessionData = sessionData,
	})
end

local function deserializeConfig(jsonStr)
	local ok, data = pcall(function()
		return HttpService:JSONDecode(jsonStr)
	end)
	if ok and data then
		if data.collectorConfig then
			for k, v in pairs(data.collectorConfig) do
				collectorConfig[k] = v
			end
		end
		if data.hitterConfig then
			for k, v in pairs(data.hitterConfig) do
				hitterConfig[k] = v
			end
		end
		if data.cozyConfig then
			for k, v in pairs(data.cozyConfig) do
				cozyConfig[k] = v
			end
		end
		if data.savedSpots then
			for i, spot in ipairs(data.savedSpots) do
				if savedSpots[i] then
					savedSpots[i].name = spot.name
					savedSpots[i].cframe = spot.cframe
				end
			end
		end
		if data.favoriteBrainrots then
			favoriteBrainrots = data.favoriteBrainrots
		end
		return true
	end
	return false
end

local function deserializeStats(jsonStr)
	local ok, data = pcall(function()
		return HttpService:JSONDecode(jsonStr)
	end)
	if ok and data and data.sessionData then
		for k, v in pairs(data.sessionData) do
			sessionData[k] = v
		end
		return true
	end
	return false
end

