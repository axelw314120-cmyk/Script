local function switchTab(index)
	if index == currentTab then return end
	local direction = index > currentTab and 1 or -1
	local oldPanel = panels[currentTab]
	local newPanel = panels[index]

	TweenService:Create(oldPanel, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Position = UDim2.new(-direction, 0, 0, 0),
	}):Play()

	newPanel.Position = UDim2.new(direction, 0, 0, 0)
	newPanel.Visible = true

	TweenService:Create(newPanel, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 0, 0),
	}):Play()

	for i, tb in ipairs(tabButtons) do
		if i == index then
			tb.BackgroundColor3 = TAB_COLORS[i]
			tb.TextColor3 = Color3.fromRGB(230, 240, 255)
		else
			tb.BackgroundColor3 = Color3.fromRGB(28, 35, 65)
			tb.TextColor3 = Color3.fromRGB(140, 155, 200)
		end
	end

	if index == 3 then refreshLog() end
	if index == 4 then
		refreshPlayerList()
		refreshServerInfo()
		refreshEquipList()
	end
	if index == 5 then
		refreshStatsUI()
		refreshEncyclopedia()
	end
	if index == 6 then
		refreshAnalyticsUI()
	end
	if index == 2 then refreshTargetChecklist() end

	currentTab = index
end

