-- ============================================================================
-- PROXIMITY OG ALERTS
-- ============================================================================

local PROXIMITY_RANGE = 120

local function scanNearbyOGs()
	if not proximityAlertsEnabled then return end
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	local pos = char.HumanoidRootPart.Position
	local mobs = workspace:FindFirstChild("Mobs")
	if not mobs then return end

	for _, mob in ipairs(mobs:GetChildren()) do
		if isBrainrot(mob.Name) and getRarity(mob) == "OG" then
			local root = mob:FindFirstChild("RootPart")
			if root and (root.Position - pos).Magnitude <= PROXIMITY_RANGE then
				if not proximityAlerted[mob.Name] then
					proximityAlerted[mob.Name] = true
					local meta = getBrainrotMeta(mob.Name)
					addLog("Nearby OG: " .. mob.Name .. " [" .. meta.tier .. "]", "Collect")
					showNotif("OG nearby: " .. mob.Name, Color3.fromRGB(255, 215, 0))
				end
			else
				proximityAlerted[mob.Name] = nil
			end
		end
	end
end

task.spawn(function()
	while screenGui.Parent do
		scanNearbyOGs()
		task.wait(2)
	end
end)

