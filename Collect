local function checkAchievements()
	for _, ach in ipairs(ACHIEVEMENTS) do
		if not sessionData.unlockedAchievements[ach.id] then
			local ok, passed = pcall(ach.check)
			if ok and passed then
				sessionData.unlockedAchievements[ach.id] = true
				addLog("Achievement unlocked: " .. ach.title, "Record")
				showNotif("Achievement: " .. ach.title, Color3.fromRGB(255, 215, 0))
				playAchievementSound()
			end
		end
	end
end

local function addRunHistory(kind, summary)
	table.insert(sessionData.runHistory, 1, "[" .. timestamp() .. "] " .. kind .. " — " .. summary)
	while #sessionData.runHistory > 25 do
		table.remove(sessionData.runHistory)
	end
end

